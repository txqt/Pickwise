<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Pickwise.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="560"
        x:Class="Pickwise.Views.MainWindow"
        x:Name="Root"
        x:DataType="vm:MainViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Width="520"
        Height="720"
        Title="Pickwise">

    <Grid>
    <ScrollViewer>
        <StackPanel Margin="28" Spacing="18">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                <StackPanel Spacing="4">
                    <TextBlock Text="Pickwise" FontSize="28" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding Status}" Foreground="#6b7280" />
                </StackPanel>
                <Button Grid.Column="1"
                        Content="Settings"
                        Command="{Binding OpenSettingsCommand}"
                        VerticalAlignment="Top" />
            </Grid>

            <StackPanel Spacing="18" IsVisible="{Binding IsHomeScreen}">
                <Button Command="{Binding OpenCurrentSummonerProfileCommand}"
                        Padding="0"
                        Background="Transparent"
                        BorderThickness="0"
                        HorizontalContentAlignment="Stretch">
                    <Border Background="#f5f5f5" CornerRadius="12" Padding="16">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Current Summoner" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding Summoner}" />
                        </StackPanel>
                    </Border>
                </Button>

                <Border Background="#f5f5f5" CornerRadius="12" Padding="18">
                    <StackPanel Spacing="16">
                        <TextBlock Text="Mode Selection" FontWeight="SemiBold" />
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="14">
                            <Button Command="{Binding SelectModeGroupCommand}"
                                    CommandParameter="Summoner's Rift"
                                    Padding="0"
                                    MinHeight="168"
                                    Background="White"
                                    BorderBrush="#e5e7eb"
                                    BorderThickness="1">
                                <Grid RowDefinitions="104,*">
                                    <Border Margin="10"
                                            Background="#f5f5f5"
                                            BorderBrush="#e5e7eb"
                                            BorderThickness="1"
                                            CornerRadius="8"
                                            ClipToBounds="True">
                                        <Grid>
                                            <Image Source="{Binding SummonersRiftIcon}"
                                                   Stretch="UniformToFill"
                                                   IsVisible="{Binding HasSummonersRiftIcon}" />
                                            <Grid IsVisible="{Binding HasNoSummonersRiftIcon}">
                                                <Border BorderBrush="#374151" BorderThickness="3" CornerRadius="14" Margin="18" />
                                                <Border Margin="32" Background="White" BorderBrush="#e5e7eb" BorderThickness="2" CornerRadius="4" />
                                                <Path Data="M18,58 L58,18"
                                                      Stroke="#374151"
                                                      StrokeThickness="4"
                                                      Stretch="Uniform"
                                                      Margin="22" />
                                            </Grid>
                                        </Grid>
                                    </Border>
                                    <StackPanel Grid.Row="1" Margin="14,0,14,14" Spacing="4">
                                        <TextBlock Text="Summoner's Rift"
                                                   Foreground="#111"
                                                   FontSize="17"
                                                   FontWeight="SemiBold"
                                                   TextAlignment="Center"
                                                   TextWrapping="Wrap" />
                                        <TextBlock Text="Classic 5v5"
                                                   Foreground="#6b7280"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   TextAlignment="Center" />
                                    </StackPanel>
                                </Grid>
                            </Button>

                            <Button Grid.Column="1"
                                    Command="{Binding SelectModeGroupCommand}"
                                    CommandParameter="ARAM"
                                    Padding="0"
                                    MinHeight="168"
                                    Background="White"
                                    BorderBrush="#e5e7eb"
                                    BorderThickness="1">
                                <Grid RowDefinitions="104,*">
                                    <Border Margin="10"
                                            Background="#f5f5f5"
                                            BorderBrush="#e5e7eb"
                                            BorderThickness="1"
                                            CornerRadius="8"
                                            ClipToBounds="True">
                                        <Grid>
                                            <Image Source="{Binding AramIcon}"
                                                   Stretch="UniformToFill"
                                                   IsVisible="{Binding HasAramIcon}" />
                                            <Grid IsVisible="{Binding HasNoAramIcon}">
                                                <Border BorderBrush="#374151" BorderThickness="3" CornerRadius="4" Margin="18" />
                                                <Path Data="M16,58 L58,16 L58,36 L36,58 Z"
                                                      Fill="White"
                                                      Stroke="#374151"
                                                      StrokeThickness="3"
                                                      Stretch="Uniform"
                                                      Margin="22" />
                                            </Grid>
                                        </Grid>
                                    </Border>
                                    <StackPanel Grid.Row="1" Margin="14,0,14,14" Spacing="4">
                                        <TextBlock Text="ARAM"
                                                   Foreground="#111"
                                                   FontSize="17"
                                                   FontWeight="SemiBold"
                                                   TextAlignment="Center" />
                                        <TextBlock Text="Random 5v5"
                                                   Foreground="#6b7280"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   TextAlignment="Center" />
                                    </StackPanel>
                                </Grid>
                            </Button>
                        </Grid>
                        <ItemsControl ItemsSource="{Binding ModeGroups}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Content="{Binding}"
                                            Command="{Binding #Root.DataContext.SelectModeGroupCommand}"
                                            CommandParameter="{Binding}"
                                            Margin="0,0,8,8" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <Border Background="#f5f5f5" CornerRadius="12" Padding="16">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Readiness" FontWeight="SemiBold" />
                        <TextBlock Text="Logs" FontSize="12" Foreground="#6b7280" />
                        <TextBlock Text="{Binding LogPath}" FontSize="12" TextWrapping="Wrap" />
                        <TextBlock Text="Champion icon cache" FontSize="12" Foreground="#6b7280" />
                        <TextBlock Text="{Binding ChampionIconCachePath}" FontSize="12" TextWrapping="Wrap" />
                        <TextBlock Text="{Binding RiotDisclaimer}" FontSize="11" Foreground="#6b7280" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </StackPanel>

            <StackPanel Spacing="18" IsVisible="{Binding IsReadyScreen}">
                <Button Content="Back" Command="{Binding BackCommand}" HorizontalAlignment="Left" />

                <Border Background="#f5f5f5" CornerRadius="12" Padding="16">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Mode Selection" FontWeight="SemiBold" />
                        <ListBox ItemsSource="{Binding GameModes}"
                                 SelectedItem="{Binding SelectedGameMode}"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 MinHeight="96">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Label}" Padding="8" />
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <Button Content="Create Lobby" Command="{Binding CreateLobbyCommand}" />
                            <Button Content="Leave Lobby" Command="{Binding LeaveLobbyCommand}" />
                        </StackPanel>
                        <StackPanel Spacing="8" IsVisible="{Binding IsPositionSelectorVisible}">
                            <TextBlock Text="Lane Preferences" FontWeight="SemiBold" />
                            <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                                <ComboBox ItemsSource="{Binding PositionOptions}"
                                          SelectedItem="{Binding SelectedPrimaryPosition}" />
                                <ComboBox Grid.Column="1"
                                          ItemsSource="{Binding PositionOptions}"
                                          SelectedItem="{Binding SelectedSecondaryPosition}" />
                            </Grid>
                            <Button Content="Save Lanes"
                                    Command="{Binding SavePositionsCommand}"
                                    HorizontalAlignment="Left" />
                        </StackPanel>
                        <TextBlock Text="{Binding LobbySetupStatus}"
                                   FontSize="12"
                                   Foreground="#6b7280"
                                   TextWrapping="Wrap"
                                   IsVisible="{Binding IsQuickplaySetupVisible}" />
                        <ItemsControl ItemsSource="{Binding QuickplaySlots}"
                                      IsVisible="{Binding HasQuickplaySlots}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:QuickplaySlotViewModel">
                                    <Button Command="{Binding #Root.DataContext.OpenQuickplaySlotCommand}"
                                            CommandParameter="{Binding}"
                                            Padding="0"
                                            Margin="0,3"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            HorizontalContentAlignment="Stretch">
                                        <Border Background="White"
                                                BorderBrush="#e5e7eb"
                                                BorderThickness="1"
                                                CornerRadius="8"
                                                Padding="10">
                                            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                                                <TextBlock Text="{Binding Slot}"
                                                           FontWeight="SemiBold"
                                                           Foreground="#374151"
                                                           VerticalAlignment="Center" />
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding Champion}"
                                                           Foreground="#111"
                                                           TextTrimming="CharacterEllipsis"
                                                           VerticalAlignment="Center" />
                                                <TextBlock Grid.Column="2"
                                                           Text="{Binding Position}"
                                                           Foreground="#6b7280"
                                                           FontWeight="SemiBold"
                                                           VerticalAlignment="Center" />
                                            </Grid>
                                        </Border>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <Border Background="#f5f5f5" CornerRadius="12" Padding="16">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Current Lobby" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding CurrentLobby}" Foreground="#374151" />
                        <ItemsControl ItemsSource="{Binding LobbyMembers}" IsVisible="{Binding HasLobbyMembers}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:LobbyMemberViewModel">
                                    <Border Background="White" BorderBrush="#e5e7eb" BorderThickness="1" CornerRadius="8" Padding="10" Margin="0,3">
                                        <Border.ContextMenu>
                                            <ContextMenu>
                                                <MenuItem Header="Check profile"
                                                          Command="{Binding #Root.DataContext.CheckProfileCommand}"
                                                          CommandParameter="{Binding}" />
                                                <MenuItem Header="Add friend"
                                                          Command="{Binding #Root.DataContext.AddFriendCommand}"
                                                          CommandParameter="{Binding}"
                                                          IsEnabled="{Binding CanAddFriend}" />
                                            </ContextMenu>
                                        </Border.ContextMenu>
                                        <Grid ColumnDefinitions="36,*,Auto" ColumnSpacing="10">
                                            <Grid Width="32" Height="32">
                                                <Image Source="{Binding Icon}"
                                                       Width="32"
                                                       Height="32"
                                                       Stretch="UniformToFill"
                                                       IsVisible="{Binding HasIcon}" />
                                                <Border Background="#f5f5f5"
                                                        BorderBrush="#e5e7eb"
                                                        BorderThickness="1"
                                                        IsVisible="{Binding HasNoIcon}">
                                                    <TextBlock Text="?"
                                                               Foreground="#6b7280"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center" />
                                                </Border>
                                            </Grid>
                                            <StackPanel Grid.Column="1" Spacing="2">
                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                                <TextBlock Text="{Binding Position}" FontSize="12" Foreground="#6b7280" />
                                            </StackPanel>
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding Badges}"
                                                       FontSize="12"
                                                       FontWeight="SemiBold"
                                                       Foreground="#374151"
                                                       VerticalAlignment="Center"
                                                       IsVisible="{Binding HasBadges}" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <Border Background="#f5f5f5" CornerRadius="12" Padding="16">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Ready Check" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding ReadyCheck}" />
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <Button Content="Find Match" Command="{Binding StartMatchmakingCommand}" />
                            <Button Content="Cancel Search" Command="{Binding CancelMatchmakingCommand}" />
                            <Button Content="Accept" Command="{Binding AcceptCommand}" />
                            <Button Content="Decline" Command="{Binding DeclineCommand}" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>

            <StackPanel Spacing="18" IsVisible="{Binding IsProfileScreen}">
                <Button Content="Back" Command="{Binding BackCommand}" HorizontalAlignment="Left" />

                <Border Background="#f5f5f5" CornerRadius="12" Padding="16">
                    <Grid RowDefinitions="Auto,Auto" RowSpacing="16">
                        <Grid ColumnDefinitions="96,*" ColumnSpacing="16">
                            <Grid Width="80" Height="80" HorizontalAlignment="Center" VerticalAlignment="Top">
                                <Image Source="{Binding SelectedProfile.IconImage}"
                                       Width="80"
                                       Height="80"
                                       Stretch="UniformToFill"
                                       IsVisible="{Binding SelectedProfile.HasIcon}" />
                                <Border Background="White"
                                        BorderBrush="#e5e7eb"
                                        BorderThickness="1"
                                        IsVisible="{Binding SelectedProfile.HasNoIcon}">
                                    <TextBlock Text="?"
                                               Foreground="#6b7280"
                                               FontSize="28"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center" />
                                </Border>
                            </Grid>
                            <StackPanel Grid.Column="1" Spacing="8">
                                <TextBlock Text="{Binding SelectedProfile.Name}"
                                           FontWeight="SemiBold"
                                           FontSize="24"
                                           Foreground="#111"
                                           TextWrapping="Wrap" />
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Border Background="White" BorderBrush="#e5e7eb" BorderThickness="1" CornerRadius="8" Padding="8,5">
                                        <TextBlock Text="{Binding SelectedProfile.Level}" FontWeight="SemiBold" Foreground="#374151" />
                                    </Border>
                                    <Border Background="White" BorderBrush="#e5e7eb" BorderThickness="1" CornerRadius="8" Padding="8,5">
                                        <TextBlock Text="{Binding SelectedProfile.Ranked}" FontWeight="SemiBold" Foreground="#374151" />
                                    </Border>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                        <Grid Grid.Row="1" ColumnDefinitions="*,*" ColumnSpacing="10">
                            <Border Background="White" BorderBrush="#e5e7eb" BorderThickness="1" CornerRadius="8" Padding="10">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="Summoner" FontSize="12" Foreground="#6b7280" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding SelectedProfile.SummonerId}" Foreground="#374151" TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="1" Background="White" BorderBrush="#e5e7eb" BorderThickness="1" CornerRadius="8" Padding="10">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="PUUID" FontSize="12" Foreground="#6b7280" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding SelectedProfile.Puuid}" Foreground="#374151" TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Grid>
                </Border>

                <Border Background="#f5f5f5" CornerRadius="12" Padding="16">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Match History" FontWeight="SemiBold" />
                        <TextBlock Text="No recent matches"
                                   Foreground="#6b7280"
                                   IsVisible="{Binding HasNoProfileMatches}" />
                        <ItemsControl ItemsSource="{Binding ProfileMatches}" IsVisible="{Binding HasProfileMatches}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:ProfileMatchViewModel">
                                    <Border Background="White"
                                            BorderBrush="#e5e7eb"
                                            BorderThickness="1"
                                            CornerRadius="8"
                                            Padding="10"
                                            Margin="0,3">
                                        <Grid RowDefinitions="Auto,Auto" RowSpacing="10">
                                            <Button Command="{Binding #Root.DataContext.ToggleProfileMatchCommand}"
                                                    CommandParameter="{Binding}"
                                                    Padding="0"
                                                    Background="Transparent"
                                                    BorderThickness="0"
                                                    HorizontalContentAlignment="Stretch">
                                                <Grid ColumnDefinitions="42,*,Auto" ColumnSpacing="10">
                                                    <Grid Width="36" Height="36">
                                                        <Image Source="{Binding ChampionIcon}"
                                                               Width="36"
                                                               Height="36"
                                                               Stretch="UniformToFill"
                                                               IsVisible="{Binding HasChampionIcon}" />
                                                        <Border Background="#f5f5f5"
                                                                BorderBrush="#e5e7eb"
                                                                BorderThickness="1"
                                                                IsVisible="{Binding HasNoChampionIcon}">
                                                            <TextBlock Text="?"
                                                                       Foreground="#6b7280"
                                                                       HorizontalAlignment="Center"
                                                                       VerticalAlignment="Center" />
                                                        </Border>
                                                    </Grid>
                                                    <StackPanel Grid.Column="1" Spacing="2">
                                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                                            <TextBlock Text="{Binding Champion}" FontWeight="SemiBold" />
                                                            <Border Background="#111"
                                                                    CornerRadius="4"
                                                                    Padding="5,2"
                                                                    IsVisible="{Binding HasViewerAward}">
                                                                <TextBlock Text="{Binding ViewerAward.Kind}"
                                                                           Foreground="White"
                                                                           FontSize="10"
                                                                           FontWeight="SemiBold" />
                                                            </Border>
                                                        </StackPanel>
                                                        <TextBlock Text="{Binding Queue}" FontSize="12" Foreground="#6b7280" TextWrapping="Wrap" />
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="2" Spacing="2" HorizontalAlignment="Right">
                                                        <TextBlock Text="{Binding Result}" FontWeight="SemiBold" Foreground="#374151" TextAlignment="Right" />
                                                        <TextBlock Text="{Binding Kda}" FontSize="12" Foreground="#374151" TextAlignment="Right" />
                                                        <TextBlock Text="{Binding Duration}" FontSize="12" Foreground="#6b7280" TextAlignment="Right" />
                                                    </StackPanel>
                                                </Grid>
                                            </Button>
                                            <Grid Grid.Row="1" RowDefinitions="Auto,Auto,Auto" RowSpacing="8" IsVisible="{Binding IsExpanded}">
                                                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                                                        <StackPanel Spacing="2">
                                                            <TextBlock Text="Combat" FontSize="12" FontWeight="SemiBold" Foreground="#6b7280" />
                                                            <TextBlock Text="{Binding ScoreLine}" FontSize="12" Foreground="#374151" />
                                                            <TextBlock Text="{Binding CombatLine}" FontSize="12" Foreground="#374151" />
                                                        </StackPanel>
                                                        <StackPanel Grid.Column="1" Spacing="2" HorizontalAlignment="Right">
                                                            <TextBlock Text="Economy" FontSize="12" FontWeight="SemiBold" Foreground="#6b7280" TextAlignment="Right" />
                                                            <TextBlock Text="{Binding EconomyLine}" FontSize="12" Foreground="#374151" TextAlignment="Right" />
                                                            <TextBlock Text="{Binding PlayedAt}" FontSize="12" Foreground="#6b7280" TextAlignment="Right" />
                                                        </StackPanel>
                                                    </Grid>
                                                    <Grid Grid.Row="1" ColumnDefinitions="Auto,*" ColumnSpacing="16">
                                                        <StackPanel Spacing="4">
                                                            <TextBlock Text="Spells" FontSize="12" FontWeight="SemiBold" Foreground="#6b7280" />
                                                            <ItemsControl ItemsSource="{Binding Spells}">
                                                                <ItemsControl.ItemsPanel>
                                                                    <ItemsPanelTemplate>
                                                                        <StackPanel Orientation="Horizontal" Spacing="4" />
                                                                    </ItemsPanelTemplate>
                                                                </ItemsControl.ItemsPanel>
                                                                <ItemsControl.ItemTemplate>
                                                                    <DataTemplate x:DataType="vm:MatchAssetViewModel">
                                                                        <Grid Width="28" Height="28" ToolTip.Tip="{Binding Label}">
                                                                            <Image Source="{Binding Icon}" Width="28" Height="28" Stretch="UniformToFill" IsVisible="{Binding HasIcon}" />
                                                                            <Border Background="#f5f5f5" BorderBrush="#e5e7eb" BorderThickness="1" IsVisible="{Binding HasNoIcon}">
                                                                                <TextBlock Text="{Binding Id}" FontSize="10" Foreground="#6b7280" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                                            </Border>
                                                                        </Grid>
                                                                    </DataTemplate>
                                                                </ItemsControl.ItemTemplate>
                                                            </ItemsControl>
                                                        </StackPanel>
                                                        <StackPanel Grid.Column="1" Spacing="4">
                                                            <TextBlock Text="{Binding ItemsLine}" FontSize="12" FontWeight="SemiBold" Foreground="#6b7280" />
                                                            <ItemsControl ItemsSource="{Binding Items}" IsVisible="{Binding HasItems}">
                                                                <ItemsControl.ItemsPanel>
                                                                    <ItemsPanelTemplate>
                                                                        <WrapPanel />
                                                                    </ItemsPanelTemplate>
                                                                </ItemsControl.ItemsPanel>
                                                                <ItemsControl.ItemTemplate>
                                                                    <DataTemplate x:DataType="vm:MatchAssetViewModel">
                                                                        <Grid Width="28" Height="28" Margin="0,0,4,4" ToolTip.Tip="{Binding Label}">
                                                                            <Image Source="{Binding Icon}" Width="28" Height="28" Stretch="UniformToFill" IsVisible="{Binding HasIcon}" />
                                                                            <Border Background="#f5f5f5" BorderBrush="#e5e7eb" BorderThickness="1" IsVisible="{Binding HasNoIcon}">
                                                                                <TextBlock Text="{Binding Id}" FontSize="10" Foreground="#6b7280" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                                            </Border>
                                                                        </Grid>
                                                                    </DataTemplate>
                                                                </ItemsControl.ItemTemplate>
                                                            </ItemsControl>
                                                        </StackPanel>
                                                    </Grid>
                                                    <Button Grid.Row="2"
                                                            Content="Chi tiet"
                                                            Command="{Binding #Root.DataContext.OpenProfileMatchDetailCommand}"
                                                            CommandParameter="{Binding}"
                                                            HorizontalAlignment="Left"
                                                            IsVisible="{Binding HasAwards}" />
                                            </Grid>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </StackPanel>

            <StackPanel Spacing="18" IsVisible="{Binding IsChampionSelectScreen}">
                <Button Content="Back" Command="{Binding BackCommand}" HorizontalAlignment="Left" />

                <Border Background="#f5f5f5" CornerRadius="12" Padding="16">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Champion Select" FontWeight="SemiBold" Foreground="#111" />
                        <TextBlock Text="{Binding ChampionSelect}" Foreground="#6b7280" />
                        <Border Background="White"
                                BorderBrush="#e5e7eb"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="8,5"
                                HorizontalAlignment="Left">
                            <TextBlock Text="{Binding ChampionSelectTimeline}" FontSize="12" FontWeight="SemiBold" Foreground="#374151" />
                        </Border>
                        <ItemsControl ItemsSource="{Binding TradeRequests}" IsVisible="{Binding HasTradeRequests}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="White" BorderBrush="#e5e7eb" BorderThickness="1" CornerRadius="8" Padding="10" Margin="0,3">
                                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                                            <TextBlock Text="{Binding State}" Foreground="#374151" VerticalAlignment="Center" />
                                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6">
                                                <Button Content="Accept"
                                                        Command="{Binding #Root.DataContext.AcceptTradeCommand}"
                                                        CommandParameter="{Binding}" />
                                                <Button Content="Decline"
                                                        Command="{Binding #Root.DataContext.DeclineTradeCommand}"
                                                        CommandParameter="{Binding}" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <StackPanel Spacing="10" IsVisible="{Binding IsRandomCardChampionSelect}">
                            <TextBlock Text="{Binding RandomCardChampionSelectLabel}" FontWeight="SemiBold" />
                            <Border Background="White"
                                    BorderBrush="#e5e7eb"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="10">
                                <StackPanel Spacing="8">
                                    <TextBlock Text="Current Champion" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding CurrentChampion}" Foreground="#374151" />
                                </StackPanel>
                            </Border>

                            <TextBlock Text="Available Champions" FontWeight="SemiBold" />
                            <ItemsControl ItemsSource="{Binding AramAvailableChampions}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:ChampionTileViewModel">
                                        <Button Command="{Binding #Root.DataContext.PickAramChampionTileCommand}"
                                                CommandParameter="{Binding}"
                                                Width="92"
                                                Padding="6"
                                                Margin="4"
                                                Background="#f5f5f5"
                                                BorderBrush="#e5e7eb"
                                                BorderThickness="1">
                                            <StackPanel Spacing="4">
                                                <Grid Width="64" Height="64" HorizontalAlignment="Center">
                                                    <Image Source="{Binding Icon}"
                                                           Width="64"
                                                           Height="64"
                                                           Stretch="UniformToFill"
                                                           IsVisible="{Binding HasIcon}" />
                                                    <Border Background="#f5f5f5"
                                                            BorderBrush="#e5e7eb"
                                                            BorderThickness="1"
                                                            IsVisible="{Binding HasNoIcon}">
                                                        <TextBlock Text="?"
                                                                   Foreground="#6b7280"
                                                                   FontSize="24"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center" />
                                                    </Border>
                                                </Grid>
                                                <TextBlock Text="{Binding Name}"
                                                           Foreground="#374151"
                                                           FontSize="11"
                                                           TextAlignment="Center"
                                                           TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <TextBlock Text="Bench" FontWeight="SemiBold" />
                            <ItemsControl ItemsSource="{Binding AramBenchChampions}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:ChampionTileViewModel">
                                        <Button Command="{Binding #Root.DataContext.SwapBenchChampionTileCommand}"
                                                CommandParameter="{Binding}"
                                                Width="92"
                                                Padding="6"
                                                Margin="4"
                                                Background="#f5f5f5"
                                                BorderBrush="#e5e7eb"
                                                BorderThickness="1">
                                            <StackPanel Spacing="4">
                                                <Grid Width="64" Height="64" HorizontalAlignment="Center">
                                                    <Image Source="{Binding Icon}"
                                                           Width="64"
                                                           Height="64"
                                                           Stretch="UniformToFill"
                                                           IsVisible="{Binding HasIcon}" />
                                                    <Border Background="#f5f5f5"
                                                            BorderBrush="#e5e7eb"
                                                            BorderThickness="1"
                                                            IsVisible="{Binding HasNoIcon}">
                                                        <TextBlock Text="?"
                                                                   Foreground="#6b7280"
                                                                   FontSize="24"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center" />
                                                    </Border>
                                                </Grid>
                                                <TextBlock Text="{Binding Name}"
                                                           Foreground="#374151"
                                                           FontSize="11"
                                                           TextAlignment="Center"
                                                           TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <StackPanel Spacing="10" IsVisible="{Binding IsFiveVFiveChampionSelect}">
                            <TextBox Watermark="Search champion" Text="{Binding ChampionSearch}" />
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button Content="Favorite" Command="{Binding ToggleFavoriteCommand}" />
                                <Button Content="Quick Ban" Command="{Binding ToggleQuickBanCommand}" />
                            </StackPanel>
                            <StackPanel Spacing="6" IsVisible="{Binding HasQuickBanChampions}">
                                <TextBlock Text="Quick Bans" FontWeight="SemiBold" />
                                <ItemsControl ItemsSource="{Binding QuickBanChampions}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:ChampionTileViewModel">
                                            <Button Command="{Binding #Root.DataContext.BanChampionTileCommand}"
                                                    CommandParameter="{Binding}"
                                                    Width="72"
                                                    Padding="4"
                                                    Margin="3"
                                                    Background="White"
                                                    BorderBrush="#e5e7eb"
                                                    BorderThickness="1">
                                                <StackPanel Spacing="4">
                                                    <Grid Width="48" Height="48" HorizontalAlignment="Center">
                                                        <Image Source="{Binding Icon}"
                                                               Width="48"
                                                               Height="48"
                                                               Stretch="UniformToFill"
                                                               IsVisible="{Binding HasIcon}" />
                                                        <Border Background="#f5f5f5"
                                                                BorderBrush="#e5e7eb"
                                                                BorderThickness="1"
                                                                IsVisible="{Binding HasNoIcon}">
                                                            <TextBlock Text="?"
                                                                       Foreground="#6b7280"
                                                                       FontSize="20"
                                                                       HorizontalAlignment="Center"
                                                                       VerticalAlignment="Center" />
                                                        </Border>
                                                    </Grid>
                                                    <TextBlock Text="{Binding Name}"
                                                               Foreground="#374151"
                                                               FontSize="11"
                                                               TextAlignment="Center"
                                                               TextTrimming="CharacterEllipsis" />
                                                </StackPanel>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                            <ItemsControl ItemsSource="{Binding ChampionRoles}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" Spacing="6" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:ChampionRoleOptionViewModel">
                                        <Button Command="{Binding #Root.DataContext.SelectChampionRoleCommand}"
                                                CommandParameter="{Binding}"
                                                ToolTip.Tip="{Binding Name}"
                                                Width="32"
                                                Height="34"
                                                Padding="4,3,4,3"
                                                Background="White"
                                                BorderBrush="#e5e7eb"
                                                BorderThickness="1">
                                            <Grid RowDefinitions="*,5">
                                                <Path Data="{Binding IconPath}"
                                                      Width="18"
                                                      Height="18"
                                                      Stretch="Uniform"
                                                      Fill="#374151"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center" />
                                                <Border Height="2"
                                                        Grid.Row="1"
                                                        Background="#111"
                                                        VerticalAlignment="Center"
                                                        IsVisible="{Binding IsSelected}" />
                                            </Grid>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <ListBox ItemsSource="{Binding Champions}"
                                     x:Name="ChampionsList"
                                     DoubleTapped="ChampionsList_DoubleTapped"
                                     SelectedItem="{Binding SelectedChampionTile}"
                                     MaxHeight="380"
                                     Background="White"
                                     BorderBrush="#e5e7eb"
                                     BorderThickness="1">
                                <ListBox.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel />
                                    </ItemsPanelTemplate>
                                </ListBox.ItemsPanel>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Width="72" Padding="4" Margin="3" Background="#f5f5f5" BorderBrush="#e5e7eb" BorderThickness="1">
                                            <StackPanel Spacing="4">
                                                <Grid Width="56" Height="56" HorizontalAlignment="Center">
                                                    <Image Source="{Binding Icon}"
                                                           Width="56"
                                                           Height="56"
                                                           Stretch="UniformToFill"
                                                           IsVisible="{Binding HasIcon}" />
                                                    <Border Background="#f5f5f5"
                                                            BorderBrush="#e5e7eb"
                                                            BorderThickness="1"
                                                            IsVisible="{Binding HasNoIcon}">
                                                        <TextBlock Text="?"
                                                                   Foreground="#6b7280"
                                                                   FontSize="24"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center" />
                                                    </Border>
                                                </Grid>
                                                <TextBlock Text="{Binding Name}"
                                                           Foreground="#374151"
                                                           FontSize="11"
                                                           TextAlignment="Center"
                                                           TextTrimming="CharacterEllipsis" />
                                                <TextBlock Text="Fav"
                                                           Foreground="#111"
                                                           FontSize="10"
                                                           FontWeight="SemiBold"
                                                           TextAlignment="Center"
                                                           IsVisible="{Binding IsFavorite}" />
                                                <TextBlock Text="Ban"
                                                           Foreground="#111"
                                                           FontSize="10"
                                                           FontWeight="SemiBold"
                                                           TextAlignment="Center"
                                                           IsVisible="{Binding IsQuickBan}" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <Button Content="Pick" Command="{Binding PickCommand}" />
                                <Button Content="Ban" Command="{Binding BanCommand}" />
                            </StackPanel>
                            <TextBlock Text="{Binding BanWarning}"
                                       Foreground="#92400e"
                                       FontWeight="SemiBold"
                                       IsVisible="{Binding HasBanWarning}" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>

            <TextBlock Text="{Binding LastCommandResult}" TextWrapping="Wrap" />
        </StackPanel>
    </ScrollViewer>
    <Border Background="#99000000"
            IsVisible="{Binding IsQuickplayEditorOpen}">
        <Border Background="White"
                BorderBrush="#e5e7eb"
                BorderThickness="1"
                CornerRadius="8"
                Padding="14"
                Width="460"
                MaxHeight="620"
                ClipToBounds="True"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
            <Grid RowDefinitions="Auto,*" RowSpacing="12">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                    <TextBlock Text="Quickplay Slots"
                               FontSize="18"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center" />
                    <Button Grid.Column="1"
                            Content="Close"
                            Command="{Binding CloseQuickplayEditorCommand}" />
                </Grid>
                <Grid Grid.Row="1"
                      ColumnDefinitions="130,*"
                      ColumnSpacing="12">
                    <StackPanel Spacing="8">
                        <ListBox ItemsSource="{Binding QuickplaySlots}"
                                 SelectedItem="{Binding ActiveQuickplaySlot}"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Padding="0">
                            <ListBox.ItemTemplate>
                                <DataTemplate x:DataType="vm:QuickplaySlotViewModel">
                                    <Border Background="White"
                                            BorderBrush="#e5e7eb"
                                            BorderThickness="1"
                                            CornerRadius="8"
                                            Padding="8"
                                            Margin="0,3">
                                        <StackPanel Spacing="4">
                                            <Grid ColumnDefinitions="*,Auto">
                                                <TextBlock Text="{Binding Slot}"
                                                           FontWeight="SemiBold" />
                                                <Border Grid.Column="1"
                                                        Width="8"
                                                        Height="8"
                                                        CornerRadius="4"
                                                        Background="#111"
                                                        IsVisible="{Binding IsActive}" />
                                            </Grid>
                                            <TextBlock Text="{Binding Champion}"
                                                       Foreground="#374151"
                                                       TextTrimming="CharacterEllipsis" />
                                            <ComboBox ItemsSource="{Binding #Root.DataContext.PositionOptions}"
                                                      SelectedItem="{Binding SelectedPosition}" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        <Button Content="Save"
                                Command="{Binding SaveQuickplaySlotsCommand}" />
                    </StackPanel>
                    <Grid Grid.Column="1" RowDefinitions="Auto,Auto,*" RowSpacing="8">
                        <ItemsControl ItemsSource="{Binding QuickplayChampionRoles}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" Spacing="6" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:ChampionRoleOptionViewModel">
                                    <Button Command="{Binding #Root.DataContext.SelectQuickplayChampionRoleCommand}"
                                            CommandParameter="{Binding}"
                                            Classes.selected="{Binding IsSelected}"
                                            ToolTip.Tip="{Binding Name}"
                                            Width="32"
                                            Height="34"
                                            Padding="4,3,4,3">
                                        <Grid RowDefinitions="*,5">
                                            <Path Data="{Binding IconPath}"
                                                  Width="18"
                                                  Height="18"
                                                  Stretch="Uniform"
                                                  Fill="#374151"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center" />
                                            <Border Height="2"
                                                    Grid.Row="1"
                                                    Background="#111"
                                                    VerticalAlignment="Center"
                                                    IsVisible="{Binding IsSelected}" />
                                        </Grid>
                                        <Button.Styles>
                                            <Style Selector="Button">
                                                <Setter Property="Background" Value="White" />
                                                <Setter Property="BorderBrush" Value="#e5e7eb" />
                                            </Style>
                                            <Style Selector="Button.selected">
                                                <Setter Property="Background" Value="White" />
                                                <Setter Property="BorderBrush" Value="#e5e7eb" />
                                            </Style>
                                        </Button.Styles>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBox Grid.Row="1"
                                 Watermark="Search champion"
                                 Text="{Binding QuickplaySearch}" />
                        <ScrollViewer Grid.Row="2">
                            <ItemsControl ItemsSource="{Binding QuickplayChampions}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:ChampionTileViewModel">
                                        <Button Command="{Binding #Root.DataContext.SelectQuickplayChampionCommand}"
                                                CommandParameter="{Binding}"
                                                Width="72"
                                                Padding="4"
                                                Margin="3"
                                                Background="#f5f5f5"
                                                BorderBrush="#e5e7eb"
                                                BorderThickness="1">
                                            <StackPanel Spacing="4">
                                                <Grid Width="56" Height="56" HorizontalAlignment="Center">
                                                    <Image Source="{Binding Icon}"
                                                           Width="56"
                                                           Height="56"
                                                           Stretch="UniformToFill"
                                                           IsVisible="{Binding HasIcon}" />
                                                    <Border Background="#f5f5f5"
                                                            BorderBrush="#e5e7eb"
                                                            BorderThickness="1"
                                                            IsVisible="{Binding HasNoIcon}">
                                                        <TextBlock Text="?"
                                                                   Foreground="#6b7280"
                                                                   FontSize="24"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center" />
                                                    </Border>
                                                </Grid>
                                                <TextBlock Text="{Binding Name}"
                                                           Foreground="#374151"
                                                           FontSize="11"
                                                           TextAlignment="Center"
                                                           TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Grid>
            </Grid>
        </Border>
    </Border>
    <Border Background="#99000000"
            IsVisible="{Binding IsSettingsOpen}">
        <Border Background="White"
                BorderBrush="#e5e7eb"
                BorderThickness="1"
                CornerRadius="8"
                Padding="16"
                Width="360"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
            <StackPanel Spacing="12">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                    <TextBlock Text="Settings"
                               FontSize="18"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center" />
                    <Button Grid.Column="1"
                            Content="Close"
                            Command="{Binding CloseSettingsCommand}" />
                </Grid>
                <CheckBox Content="Override Quickplay spells"
                          IsChecked="{Binding OverrideQuickplaySpells}" />
                <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                    <StackPanel Spacing="4">
                        <TextBlock Text="Spell 1"
                                   FontWeight="SemiBold" />
                        <ComboBox ItemsSource="{Binding SummonerSpellOptions}"
                                  SelectedItem="{Binding SelectedQuickplaySpell1}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate x:DataType="vm:SummonerSpellOptionViewModel">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <Grid Width="24" Height="24">
                                            <Image Source="{Binding Icon}"
                                                   Width="24"
                                                   Height="24"
                                                   Stretch="UniformToFill"
                                                   IsVisible="{Binding HasIcon}" />
                                            <Border Background="#f5f5f5"
                                                    BorderBrush="#e5e7eb"
                                                    BorderThickness="1"
                                                    IsVisible="{Binding HasNoIcon}">
                                                <TextBlock Text="{Binding Id}"
                                                           Foreground="#6b7280"
                                                           FontSize="10"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center" />
                                            </Border>
                                        </Grid>
                                        <TextBlock Text="{Binding Name}"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Spacing="4">
                        <TextBlock Text="Spell 2"
                                   FontWeight="SemiBold" />
                        <ComboBox ItemsSource="{Binding SummonerSpellOptions}"
                                  SelectedItem="{Binding SelectedQuickplaySpell2}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate x:DataType="vm:SummonerSpellOptionViewModel">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <Grid Width="24" Height="24">
                                            <Image Source="{Binding Icon}"
                                                   Width="24"
                                                   Height="24"
                                                   Stretch="UniformToFill"
                                                   IsVisible="{Binding HasIcon}" />
                                            <Border Background="#f5f5f5"
                                                    BorderBrush="#e5e7eb"
                                                    BorderThickness="1"
                                                    IsVisible="{Binding HasNoIcon}">
                                                <TextBlock Text="{Binding Id}"
                                                           Foreground="#6b7280"
                                                           FontSize="10"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center" />
                                            </Border>
                                        </Grid>
                                        <TextBlock Text="{Binding Name}"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>
                </Grid>
                <Button Content="Save"
                        Command="{Binding SaveSettingsCommand}"
                        HorizontalAlignment="Left" />
            </StackPanel>
        </Border>
    </Border>
    <Border Background="#99000000"
            IsVisible="{Binding IsProfileMatchDetailOpen}">
        <Border Background="White"
                BorderBrush="#e5e7eb"
                BorderThickness="1"
                CornerRadius="8"
                Padding="16"
                Width="480"
                MaxHeight="640"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
            <Grid RowDefinitions="Auto,*" RowSpacing="12">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                    <StackPanel Spacing="2">
                        <TextBlock Text="Match Detail"
                                   FontSize="18"
                                   FontWeight="SemiBold" />
                        <TextBlock Text="{Binding ProfileMatchDetail.Queue}"
                                   FontSize="12"
                                   Foreground="#6b7280" />
                    </StackPanel>
                    <Button Grid.Column="1"
                            Content="Close"
                            Command="{Binding CloseProfileMatchDetailCommand}" />
                </Grid>
                <ScrollViewer Grid.Row="1">
                    <ItemsControl ItemsSource="{Binding ProfileMatchDetail.Awards}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:MatchAwardViewModel">
                                <Border Background="#f5f5f5"
                                        BorderBrush="#e5e7eb"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="10"
                                        Margin="0,0,0,6">
                                    <Grid ColumnDefinitions="58,*" ColumnSpacing="10">
                                        <Border Background="#111"
                                                CornerRadius="4"
                                                Padding="5,3"
                                                HorizontalAlignment="Left"
                                                VerticalAlignment="Top">
                                            <TextBlock Text="{Binding Kind}"
                                                       Foreground="White"
                                                       FontSize="11"
                                                       FontWeight="SemiBold" />
                                        </Border>
                                        <StackPanel Grid.Column="1" Spacing="3">
                                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                                <TextBlock Text="{Binding PlayerName}"
                                                           FontWeight="SemiBold"
                                                           TextTrimming="CharacterEllipsis" />
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding Score}"
                                                           FontSize="12"
                                                           FontWeight="SemiBold"
                                                           Foreground="#374151" />
                                            </Grid>
                                            <TextBlock Text="{Binding Champion}"
                                                       FontSize="12"
                                                       Foreground="#374151" />
                                            <Grid ColumnDefinitions="Auto,Auto,*,Auto" ColumnSpacing="8">
                                                <TextBlock Text="{Binding Team}"
                                                           FontSize="12"
                                                           Foreground="#6b7280" />
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding Result}"
                                                           FontSize="12"
                                                           FontWeight="SemiBold"
                                                           Foreground="#374151" />
                                                <TextBlock Text="{Binding Kda}"
                                                           Grid.Column="2"
                                                           FontSize="12"
                                                           Foreground="#374151" />
                                                <TextBlock Grid.Column="3"
                                                           Text="{Binding Damage}"
                                                           FontSize="12"
                                                           Foreground="#6b7280" />
                                            </Grid>
                                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                                <TextBlock
                                                           Text="{Binding Economy}"
                                                           FontSize="12"
                                                           Foreground="#6b7280" />
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding Reason}"
                                                           FontSize="12"
                                                           Foreground="#6b7280"
                                                           TextAlignment="Right" />
                                            </Grid>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>
    </Border>
    </Grid>
</Window>
