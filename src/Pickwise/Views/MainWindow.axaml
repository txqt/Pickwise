<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Pickwise.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="560"
        x:Class="Pickwise.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Width="520"
        Height="640"
        Title="Pickwise">

    <ScrollViewer>
        <StackPanel Margin="28" Spacing="18">
            <StackPanel Spacing="4">
                <TextBlock Text="Pickwise" FontSize="28" FontWeight="SemiBold" />
                <TextBlock Text="{Binding Status}" Foreground="#666" />
            </StackPanel>

            <Border Background="#f5f5f5" CornerRadius="12" Padding="16">
                <StackPanel Spacing="8">
                    <TextBlock Text="Current Summoner" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding Summoner}" />
                </StackPanel>
            </Border>

            <Border Background="#f5f5f5" CornerRadius="12" Padding="16">
                <StackPanel Spacing="10">
                    <TextBlock Text="Mode Selection" FontWeight="SemiBold" />
                    <ComboBox ItemsSource="{Binding GameModes}"
                              SelectedItem="{Binding SelectedGameMode}"
                              HorizontalAlignment="Stretch">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Label}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <Button Content="Create Lobby" Command="{Binding CreateLobbyCommand}" />
                </StackPanel>
            </Border>

            <Border Background="#f5f5f5" CornerRadius="12" Padding="16">
                <StackPanel Spacing="10">
                    <TextBlock Text="Ready Check" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding ReadyCheck}" />
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Button Content="Accept" Command="{Binding AcceptCommand}" />
                        <Button Content="Decline" Command="{Binding DeclineCommand}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Background="#071316" CornerRadius="12" Padding="16">
                <StackPanel Spacing="10">
                    <TextBlock Text="Champion Select" FontWeight="SemiBold" Foreground="#d6e7e7" />
                    <TextBlock Text="{Binding ChampionSelect}" Foreground="#8ba3a3" />
                    <TextBox Watermark="Search champion" Text="{Binding ChampionSearch}" />
                    <ListBox ItemsSource="{Binding Champions}"
                             SelectedItem="{Binding SelectedChampionTile}"
                             MaxHeight="300"
                             Background="#0b1d22"
                             BorderBrush="#21404a"
                             BorderThickness="1">
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel />
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Width="72" Padding="4" Margin="3" Background="#10242a" BorderBrush="#2e5661" BorderThickness="1">
                                    <StackPanel Spacing="4">
                                        <Grid Width="56" Height="56" HorizontalAlignment="Center">
                                            <Image Source="{Binding Icon}"
                                                   Width="56"
                                                   Height="56"
                                                   Stretch="UniformToFill"
                                                   IsVisible="{Binding HasIcon}" />
                                            <Border Background="#16292f"
                                                    BorderBrush="#40545a"
                                                    BorderThickness="1"
                                                    IsVisible="{Binding HasNoIcon}">
                                                <TextBlock Text="?"
                                                           Foreground="#8ba3a3"
                                                           FontSize="24"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center" />
                                            </Border>
                                        </Grid>
                                        <TextBlock Text="{Binding Name}"
                                                   Foreground="#c6d5d5"
                                                   FontSize="11"
                                                   TextAlignment="Center"
                                                   TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Button Content="Pick" Command="{Binding PickCommand}" />
                        <Button Content="Ban" Command="{Binding BanCommand}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <TextBlock Text="{Binding LastCommandResult}" />
            <TextBlock Text="{Binding LogPath}" FontSize="12" Foreground="#666" TextWrapping="Wrap" />
        </StackPanel>
    </ScrollViewer>
</Window>
